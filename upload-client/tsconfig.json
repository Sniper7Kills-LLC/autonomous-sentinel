{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "outDir": "./dist",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@amplify/*": ["../amplify/*"]
    }
  },
  "include": [
    "electron/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "electron.vite.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "dist", "dist-electron", "release"]
}
