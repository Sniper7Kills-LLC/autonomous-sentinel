{
  "name": "@autonomous-sentinel/upload-client",
  "version": "0.0.0",
  "private": true,
  "description": "Autonomous Sentinel — Electron tray upload client",
  "license": "Apache-2.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-builder",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "aws-amplify": "^6.6.0",
    "chokidar": "^4.0.0",
    "electron-store": "^10.0.0",
    "keytar": "^7.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "watch.eam.autonomous-sentinel-client",
    "productName": "Autonomous Sentinel",
    "copyright": "Copyright © 2026 Sniper7Kills LLC",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**",
      "dist/**"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "AudioVideo"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
